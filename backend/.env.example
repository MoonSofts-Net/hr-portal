# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://portal_rh:portal_rh_secret@localhost:5432/portal_rh?schema=public

# Auth — use strong secrets in production (min 32 chars)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Set true to issue HttpOnly cookies instead of returning tokens in body (production)
AUTH_USE_HTTP_ONLY_COOKIES=false

# Encryption for sensitive fields (CPF etc.) — 32-byte hex key
FIELD_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Object storage: local (dev) | s3 (production / MinIO)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage/uploads
DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# S3-compatible object storage (when STORAGE_PROVIDER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=portal-rh-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGNED_URL_EXPIRY_SECONDS=300

# Integrations (placeholders)
GOVBR_ENABLED=false
WHATSAPP_ENABLED=false
PAYROLL_ENABLED=false
ACTIVE_DIRECTORY_ENABLED=false

# Email — Resend (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portal RH <admin@hrportal.com>
RESEND_ENABLED=true
APP_URL=http://localhost:3000
