# Portal RH — Next.js frontend

# Live API — proxied via Next.js to the NestJS backend (see next.config.mjs)
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_USE_MOCK_API=false
BACKEND_URL=http://localhost:3001

# Mock mode (default when API_URL unset): in-memory seed data, no backend required

# Email — Resend (also read by backend via config merge)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Portal RH <yuji@moonsofts.net>
RESEND_ENABLED=true
APP_URL=http://localhost:3000
